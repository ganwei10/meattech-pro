# 本地开发用 SQLite（Vercel 部署时在 Vercel Dashboard 设置 PostgreSQL 连接串）
DATABASE_URL="postgresql://user:password@localhost:5432/meattech"

# 会话密钥（JWT 签名用，改为随机长字符串）
SESSION_SECRET="meattech-pro-session-secret-change-in-prod-64!"

# 基础 URL（Vercel 部署时改为生产域名）
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# Cron 任务鉴权密钥（Vercel Cron 自动带上 Bearer Token）
CRON_SECRET="meattech-cron-secret-change-this"

# 邮件通知（可选，免费方案用 Resend）
# 注册 Resend 账号获取 API Key: https://resend.com
RESEND_API_KEY=""

# SMTP 配置（如不使用 Resend，可配置自有 SMTP）
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT="587"
# SMTP_USER="your@email.com"
# SMTP_PASS="your-app-password"
# SMTP_FROM="noreply@yourdomain.com"

# 短信通知 Webhook（可选，新预约时 POST 到此 URL）
# SMS_WEBHOOK="https://your-sms-service.com/send"
