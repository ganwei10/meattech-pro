generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String
  role      String   @default("EDITOR")
  phone     String?  
  company   String?  
  createdAt DateTime @default(now())
  lastLogin DateTime? // 最后登录时间
  reviews   Review[]
  favorites Favorite[]
}

model Category {
  id    Int    @id @default(autoincrement())
  name  String
  slug  String @unique
  icon  String @default("folder")
  order Int    @default(0)
  posts Post[]
}

model Post {
  id             Int      @id @default(autoincrement())
  title          String
  slug           String   @unique
  excerpt        String
  content        String
  cover          String?
  author         String   @default("MeatTech Pro")
  tags           String   @default("")
  status         String   @default("PUBLISHED")
  category       Category @relation(fields: [categoryId], references: [id])
  categoryId     Int
  featured       Boolean  @default(false)
  views          Int      @default(0)
  sourceUrl      String?  // 文章来源URL（自动爬取时填充）
  sourceName     String?  // 来源名称（如"食品伙伴网"）
  autoGenerated  Boolean  @default(false)  // 是否由定时任务自动生成
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Product {
  id          Int      @id @default(autoincrement())
  title       String
  category    String
  difficulty  String   @default("")
  reportUrl   String?
  cover       String?
  status      String   @default("PUBLISHED")
  description String   @default("")   // 产品详细描述
  content     String   @default("")   // 逆向工艺报告内容（富文本HTML）
  tags        String   @default("")   // 标签（逗号分隔）
  featured    Boolean  @default(false) // 是否推荐显示
  sortOrder   Int      @default(0)    // 排序权重
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PilotLine {
  id                Int      @id @default(autoincrement())
  name              String
  region            String
  status            String   @default("AVAILABLE")
  specs             String   @default("")
  capacity          String   @default("")
  // 新增字段
  type              String   @default("UNIVERSITY") // UNIVERSITY | PARK | ENTERPRISE
  advantages        String   @default("") // 机构核心优势
  cooperationModel  String   @default("") // 合作模式描述
  equipment         String   @default("") // 设备信息（JSON字符串或逗号分隔）
  capabilities      String   @default("") // 技术能力（JSON字符串或逗号分隔）
  contactPerson     String   @default("") // 联系人姓名
  contactPhone      String   @default("") // 联系人电话
  contactEmail      String   @default("") // 联系人邮箱
  pricePerDay       Float    @default(0)  // 每日收费标准（元）
  serviceFeePercent Float    @default(5)   // 服务费百分比（%）
  description       String   @default("") // 产线详细描述
  images            String   @default("") // 产线图片（逗号分隔的URL）
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  bookings          Booking[]
  bills             Bill[]
}

model Booking {
  id              Int      @id @default(autoincrement())
  line            PilotLine @relation(fields: [lineId], references: [id])
  lineId          Int
  contactName     String
  contactPhone    String
  contactEmail    String   @default("")
  company         String
  experimentType  String   @default("")
  requirement     String
  preferredDate   String   @default("")
  status          String   @default("PENDING")
  adminNote       String   @default("")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  // 新增关联
  bill            Bill?    // 关联的账单
  reviews         Review[] // 关联的评价
}

model Bill {
  id                Int       @id @default(autoincrement())
  bookingId         Int       @unique
  booking           Booking   @relation(fields: [bookingId], references: [id])
  lineId            Int
  line              PilotLine @relation(fields: [lineId], references: [id])
  customerName      String    // 客户姓名
  customerPhone     String    // 客户电话
  customerEmail     String    // 客户邮箱
  company           String    // 客户公司
  amount            Float     // 预约金额（产线收费）
  serviceFee        Float     // 服务费（金额 * 服务费百分比）
  totalAmount       Float     // 总金额（金额 + 服务费）
  status            String    @default("PENDING") // PENDING, PAID, CANCELLED
  invoiceRequested  Boolean   @default(false) // 是否申请发票
  invoiceInfo       String    @default("") // 发票信息（JSON）
  paidAt            DateTime? // 支付时间
  note              String    @default("") // 备注
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model Additive {
  id            Int      @id @default(autoincrement())
  name          String
  alias         String   @default("")
  casNumber     String?
  functionClass String
  maxLimit      String
  foodCategory  String
  remarks       String   @default("")
  createdAt     DateTime @default(now())
}

model TroubleshootNode {
  id        Int      @id @default(autoincrement())
  category  String
  question  String
  options   String
  isLeaf    Boolean  @default(false)
  advice    String?
  parentId  Int?
  createdAt DateTime @default(now())
}

model Setting {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String
}

model Media {
  id            Int      @id @default(autoincrement())
  filename      String   // 存储文件名（如：abc123.jpg）
  originalName  String   // 原始文件名（如：产品图片.jpg）
  url           String   // 文件访问URL（/uploads/xxx.jpg 或 https://...）
  thumbnailUrl  String?  // 视频缩略图URL（图片时为null）
  mimeType      String   // image/jpeg, video/mp4 等
  size          Int      // 文件大小（字节）
  width         Int?     // 图片宽度（视频时为null）
  height        Int?     // 图片高度（视频时为null）
  duration      Int?     // 视频时长（秒，图片时为null）
  type          String   @default("IMAGE") // IMAGE 或 VIDEO
  folder        String   @default("default") // 文件夹/分类
  alt           String   @default("") // 图片alt描述
  caption       String   @default("") // 标题/说明
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Review {
  id        Int      @id @default(autoincrement())
  bookingId Int
  booking   Booking  @relation(fields: [bookingId], references: [id])
  userId    Int?
  user      User?    @relation(fields: [userId], references: [id])
  rating    Int      // 1-5 星评分
  content   String   // 评价正文
  reply     String?  // 机构回复
  replyAt   DateTime? // 回复时间
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Favorite {
  id         Int      @id @default(autoincrement())
  userId     Int
  user       User     @relation(fields: [userId], references: [id])
  targetType String   // ARTICLE 或 PILOT_LINE
  targetId   Int
  createdAt  DateTime @default(now())

  @@unique([userId, targetType, targetId])
}
