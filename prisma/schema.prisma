generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String
  role      String   @default("EDITOR")
  phone     String?  
  company   String?  
  createdAt DateTime @default(now())
}

model Category {
  id    Int    @id @default(autoincrement())
  name  String
  slug  String @unique
  icon  String @default("folder")
  order Int    @default(0)
  posts Post[]
}

model Post {
  id             Int      @id @default(autoincrement())
  title          String
  slug           String   @unique
  excerpt        String
  content        String
  cover          String?
  author         String   @default("MeatTech Pro")
  tags           String   @default("")
  status         String   @default("PUBLISHED")
  category       Category @relation(fields: [categoryId], references: [id])
  categoryId     Int
  featured       Boolean  @default(false)
  views          Int      @default(0)
  sourceUrl      String?  // 文章来源URL（自动爬取时填充）
  sourceName     String?  // 来源名称（如"食品伙伴网"）
  autoGenerated  Boolean  @default(false)  // 是否由定时任务自动生成
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Product {
  id          Int      @id @default(autoincrement())
  title       String
  category    String
  difficulty  String
  reportUrl   String?
  cover       String?
  status      String   @default("PUBLISHED")
  createdAt   DateTime @default(now())
}

model PilotLine {
  id          Int      @id @default(autoincrement())
  name        String
  region      String
  status      String   @default("AVAILABLE")
  specs       String   @default("")
  capacity    String   @default("")
  createdAt   DateTime @default(now())
  bookings    Booking[]
}

model Booking {
  id              Int      @id @default(autoincrement())
  line            PilotLine @relation(fields: [lineId], references: [id])
  lineId          Int
  contactName     String
  contactPhone    String
  contactEmail    String   @default("")
  company         String
  experimentType  String   @default("")
  requirement     String
  preferredDate   String   @default("")
  status          String   @default("PENDING")
  adminNote       String   @default("")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Additive {
  id            Int      @id @default(autoincrement())
  name          String
  alias         String   @default("")
  casNumber     String?
  functionClass String
  maxLimit      String
  foodCategory  String
  remarks       String   @default("")
  createdAt     DateTime @default(now())
}

model TroubleshootNode {
  id        Int      @id @default(autoincrement())
  category  String
  question  String
  options   String
  isLeaf    Boolean  @default(false)
  advice    String?
  parentId  Int?
  createdAt DateTime @default(now())
}

model Setting {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String
}
